{
  "routes": [
    {
      "src": "/(.*).php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/modulo_acceso/",
      "dest": "/api/inicio_de_sesion/log.php"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  }
}
